# =============================================================================
# SU7_CarVoice_Fusion — 环境变量配置模板
# 融合了 CarVoice_Agent + XIAOMI_SU7_RAG 的全部配置项
#
# 使用方式:
#   cp .env.example .env
#   编辑 .env 填入实际值
# =============================================================================

# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=SU7 CarVoice Fusion
APP_ENV=dev
HOST=0.0.0.0
PORT=8000

# ── Orchestrator thresholds ────────────────────────────────────────────────
TASK_CONFIDENCE_THRESHOLD=0.75
FAQ_CONFIDENCE_THRESHOLD=0.65
CHITCHAT_CONFIDENCE_THRESHOLD=0.60

# ── LLM Provider (mock | doubao | vllm | openai) ──────────────────────────
LLM_PROVIDER=mock

# Doubao (ByteDance Ark) — 火山引擎豆包 API
# 获取地址: https://console.volcengine.com/ark/
# 支持两套命名: DOUBAO_ENDPOINT/MODEL 或 DOUBAO_BASE_URL/MODEL_NAME
# DOUBAO_API_KEY=ark-your-api-key-here
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL_NAME=doubao-1-5-lite-32k-250115
# DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL=doubao-1-5-lite-32k-250115

# vLLM (local deployment)
# VLLM_BASE_URL=http://127.0.0.1:8000/v1

# OpenAI (备选, baseline对比)
# OPENAI_API_KEY=sk-your-key
# OPENAI_API_BASE=https://aihubmix.com/v1
# OPENAI_MODEL_NAME=gpt-4o-free

# HuggingFace Token (门控/私有模型下载)
# HF_TOKEN=hf_your_token

# HuggingFace 国内镜像 (国内服务器必设)
# HF_ENDPOINT=https://hf-mirror.com

# ── NLP Service URLs (from CarVoice_Agent) ─────────────────────────────────
# 微服务地址，如果使用 scripts/start_all_services.sh 一键启动则无需修改
# REJECT_URL=http://127.0.0.1:8007/reject-server/v1
# INTENT_URL=http://127.0.0.1:8008/intent-server/v1
# NLU_URL=http://127.0.0.1:8009/chatnlu-server/v1
# ENTRY_URL=http://127.0.0.1:8080/request_nlu

# 微服务端口 (start_all_services.sh 使用)
# ENTRY_PORT=8080
# REJECT_PORT=8007
# INTENT_PORT=8008
# NLU_PORT=8009

# 拒识阈值
# REJECT_THRESHOLD=0.3

# ── BERT Model Paths (from CarVoice_Agent) ─────────────────────────────────
# 训练产出路径
# INTENT_MODEL_PATH=models/saved/intent/bert.ckpt
# REJECT_MODEL_PATH=models/saved/reject/bert_tiny.ckpt
# 预训练模型路径
# INTENT_BERT_PATH=models/chinese_roberta_wwm_ext
# REJECT_BERT_PATH=models/roberta_tiny_clue

# ── Redis (optional — session/cache persistence) ───────────────────────────
# 支持 REDIS_HOST/PORT/DBID 或 REDIS_URL 两种方式
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DBID=0
# REDIS_URL=redis://127.0.0.1:6379/0

# ── Knowledge / RAG (from XIAOMI_SU7_RAG) ──────────────────────────────────
# 检索后端: mock | bm25 | milvus | hybrid
#   mock   — 零依赖，TF 打分（开发测试用）
#   bm25   — BM25 关键词检索（jieba 分词）
#   milvus — BGE-Large-zh-v1.5 + SPLADE v2 混合向量检索
#   hybrid — BM25 + Milvus/FAISS 双路召回 + WRRF 融合（完整管线）
# 重排后端: mock | minicpm
# 向量后端: milvus | faiss (hybrid 模式下的 Dense 后端)
KNOWLEDGE_TOP_K=3
WEB_SEARCH_ENABLED=false
KNOWLEDGE_DOCS_PATH=data/knowledge/su7_docs.json
RETRIEVER_BACKEND=mock
RERANKER_BACKEND=mock
HYBRID_DENSE_BACKEND=milvus
MILVUS_URI=data/knowledge/saved_index/milvus.db

# ── Web Search (from XIAOMI_SU7_RAG) ───────────────────────────────────────
# 网络搜索后端优先级: SerpAPI → Serper → Bing → Doubao 模拟
# SerpAPI: https://serpapi.com/manage-api-key (免费额度 100 次/月)
# Serper:   https://serper.dev/api-keys (免费额度 2,500 次)
# SERPAPI_KEY=your-serpapi-key
# SERPER_API_KEY=your-serper-api-key
# BING_SEARCH_KEY=

# ── MongoDB (from XIAOMI_SU7_RAG — 文档元数据存储) ─────────────────────────
# MONGO_HOST=localhost
# MONGO_PORT=27017
# MONGO_DB_NAME=mydatabase
# MONGO_USERNAME=
# MONGO_PASSWORD=
# MONGO_AUTH_SOURCE=admin

# ── MCP / External APIs (from CarVoice_Agent) ──────────────────────────────
# 高德地图 API Key: https://lbs.amap.com/
# AMAP_API_KEY=your_amap_api_key_here

# ── RL / Training ───────────────────────────────────────────────────────────
# RL_MODEL_NAME=su7_rl
# GRPO_BASE_MODEL=models/Qwen3-8B
# GRPO_SFT_ADAPTER=models/qwen3_lora_sft

# ── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Semantic Chunk ──────────────────────────────────────────────────────────
# SEMANTIC_CHUNK_URL=http://127.0.0.1:6000/v1/semantic-chunks
# CHUNK_MODEL_PATH=models/moka-ai/m3e-small
# 语义切分服务地址 (build_index.py 可选使用)
# SEMANTIC_CHUNK_URL=http://localhost:6000/v1/semantic-chunks

# ── Data paths ─────────────────────────────────────────────────────────────
ABBR_CSV_PATH=data/abbr/abbr_ch.csv
# RAG_BASE_DIR=/root/autodl-tmp  # 项目根目录 (可选, 默认自动检测)

# ── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
