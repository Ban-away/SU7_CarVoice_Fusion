# ── App ──
APP_NAME=SU7 CarVoice Fusion
APP_ENV=dev
HOST=0.0.0.0
PORT=8000

# ── Orchestrator thresholds ──
TASK_CONFIDENCE_THRESHOLD=0.75
FAQ_CONFIDENCE_THRESHOLD=0.65
CHITCHAT_CONFIDENCE_THRESHOLD=0.60

# ── LLM ──
LLM_PROVIDER=mock
# DOUBAO_API_KEY=
# DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL=ep-20240601170316-5dhwt
# VLLM_BASE_URL=http://127.0.0.1:8000/v1

# ── NLP Services ──
# NLU_URL=
# REJECT_URL=

# ── Redis (optional) ──
# REDIS_URL=redis://127.0.0.1:6379/0

# ── Knowledge / RAG ──
KNOWLEDGE_TOP_K=3
WEB_SEARCH_ENABLED=false
KNOWLEDGE_DOCS_PATH=data/knowledge/su7_docs.json
RETRIEVER_BACKEND=mock
RERANKER_BACKEND=mock
# MILVUS_HOST=127.0.0.1
# MILVUS_PORT=19530

# ── MCP ──
# AMAP_API_KEY=

# ── Data ──
ABBR_CSV_PATH=data/abbr/abbr_ch.csv
