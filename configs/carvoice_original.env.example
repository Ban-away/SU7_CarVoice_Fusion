# 火山引擎豆包 API 配置
DOUBAO_API_KEY=your_api_key_here
DOUBAO_MODEL_NAME=doubao-1-5-lite-32k-250115
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DBID=0

# 微服务地址
REJECT_URL=http://127.0.0.1:8007/reject-server/v1
INTENT_URL=http://127.0.0.1:8008/intent-server/v1
NLU_URL=http://127.0.0.1:8009/chatnlu-server/v1

# 入口服务
ENTRY_URL=http://127.0.0.1:8080/request_nlu
ENTRY_PORT=8080

# 服务端口
REJECT_PORT=8007
INTENT_PORT=8008
NLU_PORT=8009

# 拒识阈值
REJECT_THRESHOLD=0.3

# 日志级别
LOG_LEVEL=INFO

# 地图服务
AMAP_MAPS_API_KEY=your_amap_api_key_here
