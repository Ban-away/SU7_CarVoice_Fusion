# =============================================================================
# SU7_CarVoice_Fusion .gitignore
# 合并自 CarVoice_Agent + XIAOMI_SU7_RAG 的忽略规则
# =============================================================================

# =============================================================================
# 1. 模型权重文件（大文件，不上传）
# =============================================================================
*.bin
*.pth
*.pt
*.ckpt
*.h5
*.hdf5
*.onnx
*.safetensors
*.model
*.weights

# 压缩包（可能包含模型）
*.tar
*.tar.gz
*.zip
*.rar
*.7z

# 模型 & 训练产物目录
model/
models/
checkpoint/
checkpoints/
pretrained/
saved/
output/
runs/
wandb/
mlruns/
LLaMA-Factory-main/

# =============================================================================
# 2. 数据库文件
# =============================================================================
mongodb/
mongodb-*/
data/mongodb/
*.db-journal

# =============================================================================
# 3. Python 缓存 & 虚拟环境
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/

# 环境变量（含密钥）
.env
.env.local

# =============================================================================
# 4. 测试 & 覆盖率
# =============================================================================
.pytest_cache/
htmlcov/
.coverage
*.cover

# =============================================================================
# 5. IDE & 编辑器
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# 6. 系统文件
# =============================================================================
.DS_Store
Thumbs.db
*.tmp
*.temp

# =============================================================================
# 7. 日志
# =============================================================================
*.log
log/
logs/

# =============================================================================
# 8. 临时 & 结果目录
# =============================================================================
result/
results/
tmp/
temp/

# =============================================================================
# 9. 允许跟踪的文件（覆盖上级规则）
# =============================================================================
# 预构建的检索索引和预处理文档（项目资产，非模型权重）
!data/knowledge/saved_index/*.pkl
!data/knowledge/processed_docs/*.pkl

# PDF 提取图片（体积大，不跟踪）
data/knowledge/saved_images/
